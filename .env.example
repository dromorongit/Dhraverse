# Database
DATABASE_URL="postgresql://username:password@localhost:5432/dhraverse"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Paystack Payment Gateway Keys (get from https://paystack.com/)
PAYSTACK_PUBLIC_KEY="pk_test_your_public_key"
PAYSTACK_SECRET_KEY="sk_test_your_secret_key"
PAYSTACK_BASE_URL="https://api.paystack.co"

# Brevo Email Service (get from https://www.brevo.com/)
BREVO_API_KEY="your-brevo-api-key"
BREVO_SENDER_EMAIL="noreply@yourdomain.com"
BREVO_SENDER_NAME="Your Company Name"